# AI Money Manager - Environment Configuration
# Copy this file to .env and fill in real values

# Environment: development | production
ENV=development

# Backend
SECRET_KEY=change-this-to-a-random-32-char-string
GROQ_API_KEY=your-groq-api-key-here
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost

# Database (SQLite default, PostgreSQL for production)
# DATABASE_URL=sqlite:///ai_money_manager.db
# DATABASE_URL=postgresql://user:pass@postgres:5432/aimoney

# Admin (default admin created on first startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisAdminPassword123

# Frontend (set at build time for Docker)
VITE_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost

# SMTP Email (leave blank in dev to log to console)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@ai-money-manager.com

# Error Tracking (production only)
SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
